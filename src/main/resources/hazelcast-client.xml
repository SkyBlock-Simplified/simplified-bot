<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hazelcast client configuration for the simplified-bot Phase 6c WriteDispatcher
  SDK. This file is loaded from the classpath on the first call to
  HazelcastClient.newHazelcastClient() inside WriteDispatcher.createClient().

  IMPORTANT: this file MUST stay in sync with the canonical copy at
  infra/hazelcast/hazelcast-client.xml and with the sibling copy at
  simplified-data/src/main/resources/hazelcast-client.xml. Any edit to one
  MUST be applied to all three. A future phase should consolidate to a
  shared resource (gradle resources copy task or symlink).

  Phase 6c is SDK-only - WriteDispatcher is not eagerly instantiated from
  SimplifiedBot.main() or bootstrap(), so the address below is never actually
  dialed at bot startup. This file is here so that when a concrete caller
  activates the dispatcher in a later phase, the default classpath config
  exists and matches the cluster.

  The address `hazelcast:5701` resolves via docker-internal DNS when
  simplified-bot runs as a container on `skyblock-hazelcast-net`. Operators
  running simplified-bot on the developer host MUST override this via the
  `hazelcast.client.config` system property pointing at a different XML file,
  because port 5701 is expose-only on the cluster and not published to the
  host per the locked security decision in architecture_simplified_data_initiative.md.
-->
<hazelcast-client xmlns="http://www.hazelcast.com/schema/client-config"
                  xsi:schemaLocation="http://www.hazelcast.com/schema/client-config
                  http://www.hazelcast.com/schema/client-config/hazelcast-client-config-5.6.xsd"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <cluster-name>skyblock</cluster-name>

    <network>
        <cluster-members>
            <address>hazelcast:5701</address>
        </cluster-members>
        <connection-timeout>5000</connection-timeout>
        <cluster-routing mode="ALL_MEMBERS"/>
    </network>

    <connection-strategy async-start="false" reconnect-mode="ON">
        <connection-retry>
            <initial-backoff-millis>1000</initial-backoff-millis>
            <max-backoff-millis>15000</max-backoff-millis>
            <multiplier>2</multiplier>
            <cluster-connect-timeout-millis>30000</cluster-connect-timeout-millis>
            <jitter>0.2</jitter>
        </connection-retry>
    </connection-strategy>

</hazelcast-client>
